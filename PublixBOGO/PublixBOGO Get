$To = 'pvb.anime.0602@outlook.com'
$folder = 'C:\PublixBOGO'

Push-Location $folder
$json = node .\bogo-scraper.js 2>$null
Pop-Location

if (-not $json) { exit }

$data = $json | ConvertFrom-Json
if ($data.error) { exit }

$html = $data.html

$outlook = New-Object -ComObject Outlook.Application
$mail = $outlook.CreateItem(0)
$mail.To = $To
$mail.Subject = 'Publix Weekly BOGO Deals'
$mail.HTMLBody = $html
$mail.Send()