# =====================================================================
# TECH NEWS DAILY — HTML + PDF VERSION (OUTLOOK CLIENT SEND)
# =====================================================================

$ErrorActionPreference = "Stop"
[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12

$BasePath  = "C:\TechNewsDaily"
$Date      = (Get-Date).ToString("yyyy-MM-dd")
$HtmlFile  = "$BasePath\TechNews_$Date.html"
$PdfFile   = "$BasePath\TechNews_$Date.pdf"
$LogFile   = "$BasePath\TechNews.log"
$EmailFile = "$BasePath\email.txt"

$EmailTo = Get-Content $EmailFile

$EmailSubject = "TechNewsDaily"
$EmailBody    = "<h2>Your Daily Tech News Report for $Date</h2><p>PDF attached.</p>"

# =====================================================================
# FEEDS
# =====================================================================

$Feeds = @(
    "https://feeds.arstechnica.com/arstechnica/technology-lab",
    "https://www.wired.com/feed/rss",
    "https://techcrunch.com/feed/",
    "https://www.theverge.com/rss/index.xml",
    "https://www.engadget.com/rss.xml",
    "https://www.zdnet.com/news/rss.xml",
    "https://www.cnet.com/rss/news/",
    "https://krebsonsecurity.com/feed/",
    "https://www.bleepingcomputer.com/feed/",
    "https://www.darkreading.com/rss.xml",
    "https://www.microsoft.com/en-us/security/blog/feed/",
    "https://azure.microsoft.com/en-us/blog/feed/",
    "https://aws.amazon.com/about-aws/whats-new/recent/feed/",
    "https://cloud.google.com/blog/topics/rss.xml",
    "https://openai.com/blog/rss/",
    "https://ai.googleblog.com/feeds/posts/default",
    "https://developer.nvidia.com/blog/feed/"
)

Add-Type -AssemblyName System.Web

# =====================================================================
# CLEAN NODE (fixes System.Xml.XmlElement)
# =====================================================================

function Clean-Node {
    param($Node)

    if (-not $Node) { return "" }

    if ($Node -is [System.Xml.XmlNode]) {
        $text = $Node.InnerText
    } else {
        $text = [string]$Node
    }

    $text = ($text -replace "<[^>]+>", " ")
    $text = [System.Web.HttpUtility]::HtmlDecode($text)
    $text = $text -replace "\s+", " "
    $text = $text.Trim()

    return $text
}

# =====================================================================
# SUMMARY
# =====================================================================

function Get-Summary {
    param($Text)

    $clean = Clean-Node $Text
    if (-not $clean) { return "" }

    $sentences = $clean -split "(?<=[\.!\?])\s+"

    if ($sentences.Count -gt 2) {
        $summary = ($sentences[0..1] -join " ")
    } else {
        $summary = $clean
    }

    if ($summary.Length -gt 400) {
        $summary = $summary.Substring(0, 400) + "..."
    }

    return $summary
}

# =====================================================================
# START HTML DOCUMENT (SAFE HEADER)
# =====================================================================

$Content = @"
<html>
<head>
<meta charset='UTF-8'>
<style>
body { font-family: Arial, sans-serif; line-height: 1.5; }
h1 { color: #333; }
h2 { color: #444; margin-top: 30px; }
.article { margin-bottom: 20px; padding-bottom: 10px; border-bottom: 1px solid #ccc; }
.title { font-size: 18px; font-weight: bold; }
.summary { font-style: italic; color: #555; }
</style>
</head>
<body>
<h1>Daily Technology News — $Date</h1>
"@

$Seen = @{}

# =====================================================================
# PROCESS FEEDS
# =====================================================================

foreach ($Feed in $Feeds) {
    try {
        $Headers = @{
            "User-Agent" = "Mozilla/5.0"
            "Accept"      = "*/*"
        }

        $response = Invoke-WebRequest -Uri $Feed -Headers $Headers -UseBasicParsing
        $raw = $response.Content.Trim()

        $Content += "<h2>Source: $Feed</h2>"

        if ($raw.Contains("<rss")) {
            $rss   = [xml]$raw
            $items = $rss.rss.channel.item | Select-Object -First 10
        }
        elseif ($raw.Contains("<feed")) {
            $atom  = [xml]$raw
            $items = $atom.feed.entry | Select-Object -First 10
        }
        elseif ($raw.StartsWith("{") -or $raw.StartsWith("[")) {
            $json = $raw | ConvertFrom-Json
            if ($json.items) {
                $items = $json.items | Select-Object -First 10
            } else {
                throw "JSON feed format not recognized"
            }
        }
        else {
            throw "Unsupported or blocked feed format"
        }

        foreach ($item in $items) {

            $title = Clean-Node $item.title
            if (-not $title) { continue }

            if ($item.link.href)      { $link = Clean-Node $item.link.href }
            elseif ($item.link)       { $link = Clean-Node $item.link }
            elseif ($item.url)        { $link = Clean-Node $item.url }
            else                      { $link = Clean-Node $Feed }

            if ($item.summary) {
                $desc = Clean-Node $item.summary
            }
            elseif ($item.description) {
                $desc = Clean-Node $item.description
            }
            elseif ($item.'content:encoded') {
                $desc = Clean-Node $item.'content:encoded'
            }
            elseif ($item.content) {
                $desc = Clean-Node $item.content
            }
            elseif ($item.'media:group') {
                $desc = Clean-Node $item.'media:group'
            }
            else {
                $desc = ""
            }

            $key = "$title|$link".ToLower()
            if ($Seen.ContainsKey($key)) { continue }
            $Seen[$key] = $true

            $summary = Get-Summary $desc

            $Content += @"
<div class='article'>
  <div class='title'><a href='$link'>$title</a></div>
  <div><a href='$link'>$link</a></div>
  <div class='summary'>$summary</div>
</div>
"@
        }
    }
    catch {
        Add-Content -Path $LogFile -Value "$(Get-Date) - Failed feed $Feed - $($_.Exception.Message)"
    }
}

$Content += "</body></html>"

# =====================================================================
# SAVE HTML (UTF‑8 NO BOM FOR POWERSHELL 5.1)
# =====================================================================

[System.IO.File]::WriteAllText(
    $HtmlFile,
    $Content,
    (New-Object System.Text.UTF8Encoding($false))
)

Add-Content -Path $LogFile -Value "$(Get-Date) - Created HTML $HtmlFile"

# =====================================================================
# PDF EXPORT (EDGE HEADLESS)
# =====================================================================

$EdgePaths = @(
    "$env:ProgramFiles\Microsoft\Edge\Application\msedge.exe",
    "$env:ProgramFiles(x86)\Microsoft\Edge\Application\msedge.exe"
)

$EdgeExe = $EdgePaths | Where-Object { Test-Path $_ } | Select-Object -First 1

if (-not $EdgeExe) {
    Add-Content -Path $LogFile -Value "$(Get-Date) - ERROR: Edge not found. PDF not created."
} else {
    try {
        if (Test-Path $PdfFile) { Remove-Item $PdfFile -Force }

        Start-Process -FilePath $EdgeExe `
            -ArgumentList "--headless", "--disable-gpu", "--print-to-pdf=$PdfFile", "`"$HtmlFile`"" `
            -NoNewWindow -Wait

        $timeout = 0
        while (!(Test-Path $PdfFile) -and $timeout -lt 20) {
            Start-Sleep -Milliseconds 500
            $timeout++
        }

        if (Test-Path $PdfFile) {
            Add-Content -Path $LogFile -Value "$(Get-Date) - PDF created successfully: $PdfFile"
        } else {
            Add-Content -Path $LogFile -Value "$(Get-Date) - ERROR: PDF generation failed."
        }
    }
    catch {
        Add-Content -Path $LogFile -Value "$(Get-Date) - PDF export FAILED - $($_.Exception.Message)"
    }
}

# =====================================================================
# SEND EMAIL (HTML + PDF)
# =====================================================================

try {
    $Outlook = New-Object -ComObject Outlook.Application
    $Mail    = $Outlook.CreateItem(0)

    $Mail.To       = $EmailTo
    $Mail.Subject  = $EmailSubject
    $Mail.HTMLBody = $EmailBody

    if (Test-Path $PdfFile) {
        $Mail.Attachments.Add($PdfFile)
    }

    $Mail.Send()
    Add-Content -Path $LogFile -Value "$(Get-Date) - Email sent via Outlook client to $EmailTo"
}
catch {
    Add-Content -Path $LogFile -Value "$(Get-Date) - Email FAILED via Outlook client - $($_.Exception.Message)"
}
