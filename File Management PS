# Make sure OneDrive is turned off before manipulating files if you are not running in a sandbox enviroment. All changes will replicate across computers and accounts if you dont do it on local machine
# This script was designed to to run on primary admin computer account. It will create a master library folder structure and sort files from the desktop and downloads into it. It will also rename files with a consistent format and archive old files. The script is idempotent and can be run multiple times without causing issues. Make sure to customize the folder structure and file type mappings to fit your needs before running.
# ============================
# CONFIGURATION
# ============================

$root = "C:\Users\pbank\Documents\_MasterLibrary"

# Auto-detect Desktop and Downloads (OneDrive-safe)
$desktop = [Environment]::GetFolderPath("Desktop")
$downloads = [Environment]::GetFolderPath("MyDocuments").Replace("Documents","Downloads")

$sources = @($desktop, $downloads)

# Log file
$log = "$root\automation_log.txt"

Function Log($msg) {
    Add-Content -Path $log -Value "$(Get-Date -Format 'yyyy-MM-dd HH:mm:ss') - $msg"
}

