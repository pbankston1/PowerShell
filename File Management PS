# ============================
# SORTING ENGINE
# ============================

Function Sort-Files {

    $mapping = @{
        "ps1" = "$root\01_Work-IT\Scripts"
        "cmd" = "$root\01_Work-IT\Scripts"
        "bat" = "$root\01_Work-IT\Scripts"
        "log" = "$root\01_Work-IT\Documentation"
        "csv" = "$root\01_Work-IT\Documentation"

        "doc"  = "$root\02_Resumes"
        "docx" = "$root\02_Resumes"

        "ppt"  = "$root\03_School"
        "pptx" = "$root\03_School"
        "xlsx" = "$root\03_School"

        "txt" = "$root\04_Personal"

        "exe" = "$root\05_CPU-Files\Installers"
        "msi" = "$root\05_CPU-Files\Installers"
        "dll" = "$root\05_CPU-Files\Utilities"

        "png" = "$root\06_Small-Business\Merch_Designs"
        "jpg" = "$root\06_Small-Business\Merch_Designs"
        "jpeg" = "$root\06_Small-Business\Merch_Designs"

        "json" = "$root\07_Projects\Coding"
        "xml"  = "$root\07_Projects\Coding"

        "tif" = "$root\08_Medical\Imaging"
        "tiff" = "$root\08_Medical\Imaging"

        "mp4" = "$root\10_Photos-Media"
        "mov" = "$root\10_Photos-Media"
        "mp3" = "$root\10_Photos-Media"
    }

    foreach ($source in $sources) {

        if (-not (Test-Path $source)) {
            Log "SKIPPED source (not found): $source"
            continue
        }

        Get-ChildItem -Path $source -File -Recurse | ForEach-Object {

            $ext = $_.Extension.TrimStart('.').ToLower()

            if ($mapping.ContainsKey($ext)) {

                $dest = $mapping[$ext]
                if (-not (Test-Path $dest)) { New-Item -ItemType Directory -Path $dest | Out-Null }

                try {
                    Move-Item -Path $_.FullName -Destination $dest -Force -ErrorAction Stop
                    Log "Moved: $($_.Name) -> $dest"
                }
                catch {
                    Log "SKIPPED (locked or error): $($_.FullName)"
                }
            }
        }
    }
}

# ============================
# RENAMING ENGINE (SAFE)
# ============================
# This is the renaming convetion I started with. Will most likely shorten it but change text around to fit whatever naming convention you want.

Function Rename-Files {

    Get-ChildItem -Path $root -File -Recurse | ForEach-Object {

        $folder = Split-Path $_.DirectoryName -Leaf
        $date = $_.LastWriteTime.ToString("yyyy-MM-dd")
        $name = $_.BaseName -replace '[^a-zA-Z0-9\- ]',''
        $ext = $_.Extension

        $newName = "$date - $folder - $name - v1$ext"
        $newPath = Join-Path $_.DirectoryName $newName

        try {
            Rename-Item -Path $_.FullName -NewName $newName -ErrorAction Stop
            Log "Renamed: $($_.Name) -> $newName"
        }
        catch {
            Log "SKIPPED rename (locked or too long): $($_.FullName)"
        }
    }
}

# ============================
# ARCHIVE ENGINE
# ============================

Function Archive-OldFiles {

    $cutoff = (Get-Date).AddMonths(-12)

    Get-ChildItem -Path $root -File -Recurse | ForEach-Object {

        if ($_.LastWriteTime -lt $cutoff) {

            $year = $_.LastWriteTime.Year
            $archivePath = "$root\11_Archive\$year"

            if (-not (Test-Path $archivePath)) {
                New-Item -ItemType Directory -Path $archivePath | Out-Null
            }

            try {
                Move-Item -Path $_.FullName -Destination $archivePath -ErrorAction Stop
                Log "Archived: $($_.Name) -> $archivePath"
            }
            catch {
                Log "SKIPPED archive (locked): $($_.FullName)"
            }
        }
    }
}

# ============================
# CLEAN DESKTOP (OneDrive-safe)
# ============================

Function Clean-Desktop {

    $desktop = [Environment]::GetFolderPath("Desktop")

    if (-not (Test-Path $desktop)) {
        Log "Desktop not found: $desktop"
        return
    }

    Get-ChildItem -Path $desktop -File | Where-Object { $_.Extension -ne ".lnk" } | ForEach-Object {

        try {
            Move-Item -Path $_.FullName -Destination "$root\04_Personal\Misc" -ErrorAction Stop
            Log "Desktop cleaned: $($_.Name)"
        }
        catch {
            Log "SKIPPED desktop file (locked): $($_.FullName)"
        }
    }
}

# ============================
# RUN EVERYTHING
# ============================

Create-FolderStructure
Sort-Files
Rename-Files
Archive-OldFiles
Clean-Desktop

Log "Automation cycle complete."
Write-Host "Automation complete."
